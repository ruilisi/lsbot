# lingti-bot-example.yaml
# Copy this file to ~/.lsbot.yaml and fill in your credentials.
# Only configure sections relevant to your setup — everything is optional.
#
# Usage:
#   cp .lsbot.yaml.example ~/.lsbot.yaml

# ── AI Providers ──────────────────────────────────────────────────────────────
# Define named providers; reference them by key in agents or relay.provider.
# You can define multiple providers and switch between them without restarting.

providers:
  deepseek:
    provider: deepseek
    api_key: sk-YOUR_DEEPSEEK_KEY
    base_url: https://api.deepseek.com/v1
    model: deepseek-chat

  kimi:
    provider: kimi
    api_key: sk-YOUR_KIMI_KEY
    model: kimi-k2.5

  minimax:
    provider: minimax
    api_key: sk-YOUR_MINIMAX_KEY
    base_url: https://api.minimax.chat/v1
    model: MiniMax-M2.5

  claude:
    provider: claude
    api_key: sk-ant-YOUR_ANTHROPIC_KEY
    model: claude-sonnet-4-20250514

  openai:
    provider: openai
    api_key: sk-YOUR_OPENAI_KEY
    model: gpt-4o

  gemini:
    provider: gemini
    api_key: YOUR_GEMINI_KEY
    model: gemini-2.0-flash

  qwen:
    provider: qwen
    api_key: sk-YOUR_QWEN_KEY
    model: qwen-turbo

  ollama:
    provider: ollama
    base_url: http://localhost:11434/v1
    model: llama3.2

# ── Agents ────────────────────────────────────────────────────────────────────
# Each agent is an independent AI persona with its own provider, instructions,
# and workspace directory. Use `lingti-bot agents add` to add interactively.
#
# Fields:
#   id           — unique key, referenced in bindings
#   default      — true = used when no binding matches
#   provider     — references a key in `providers` above (or inline provider name)
#   api_key      — overrides the provider's api_key (optional)
#   model        — overrides the provider's model (optional)
#   instructions — system prompt text, or path to a .md/.txt file
#   workspace    — root directory for file operations (defaults to ~/.lingti/agents/<id>)
#   allow_tools  — whitelist of MCP tool names; empty = allow all
#   deny_tools   — blacklist of MCP tool names (applied after allowlist)

agents:
  - id: default
    default: true
    provider: deepseek    # references providers.deepseek above
    instructions: "You are a helpful assistant."
    workspace: ~/Projects

  - id: coder
    provider: claude
    instructions: |
      You are an expert software engineer. Focus on writing clean, efficient code.
      Always explain your reasoning before making changes.
    workspace: ~/Projects
    deny_tools:
      - file_trash         # don't allow deleting to trash
      - notification_send  # no desktop popups

  - id: writer
    provider: kimi
    instructions: ~/agents/writer-instructions.md   # load from file
    workspace: ~/Documents/writing

# ── Bindings ──────────────────────────────────────────────────────────────────
# Map incoming messages to agents based on platform and/or channel ID.
# Rules are checked top-to-bottom; first match wins.
# If no binding matches, the agent marked default:true is used.
#
# Use `lingti-bot agents bind <agent-id> --bind <platform>[:<channel_id>]` to add.

bindings:
  - agent_id: coder
    comment: "Slack #dev channel → coder agent"
    match:
      platform: slack
      channel_id: C12345ABCDE

  - agent_id: writer
    comment: "All Telegram messages → writer agent"
    match:
      platform: telegram

  - agent_id: default
    comment: "Everything else"
    match: {}

# ── Relay ─────────────────────────────────────────────────────────────────────
# Run lingti-bot as a bot on one platform.
# platform: wecom | feishu | slack | wechat

relay:
  platform: wecom
  provider: kimi        # references a key in providers above

# ── Platforms ─────────────────────────────────────────────────────────────────
# Fill in credentials for whichever platform(s) you use.
# Use `lingti-bot channels add` to configure interactively.
# Unused platforms can be left commented out or removed entirely.

platforms:
  wecom:
    corp_id: "YOUR_CORP_ID"
    agent_id: "YOUR_AGENT_ID"
    secret: "YOUR_SECRET"
    token: "YOUR_TOKEN"
    aes_key: "YOUR_AES_KEY"

  feishu:
    app_id: "YOUR_APP_ID"
    app_secret: "YOUR_APP_SECRET"

  slack:
    bot_token: "xoxb-YOUR_BOT_TOKEN"
    app_token: "xapp-YOUR_APP_TOKEN"

  telegram:
    token: "YOUR_BOT_TOKEN"

  discord:
    token: "YOUR_BOT_TOKEN"

  dingtalk:
    client_id: "YOUR_CLIENT_ID"
    client_secret: "YOUR_CLIENT_SECRET"

  whatsapp:
    phone_number_id: "YOUR_PHONE_NUMBER_ID"
    access_token: "YOUR_ACCESS_TOKEN"
    verify_token: "YOUR_VERIFY_TOKEN"

  line:
    channel_secret: "YOUR_CHANNEL_SECRET"
    channel_token: "YOUR_CHANNEL_TOKEN"

  teams:
    app_id: "YOUR_APP_ID"
    app_password: "YOUR_APP_PASSWORD"
    tenant_id: "YOUR_TENANT_ID"

  matrix:
    homeserver_url: "https://matrix.org"
    user_id: "@bot:matrix.org"
    access_token: "YOUR_ACCESS_TOKEN"

  mattermost:
    server_url: "https://your-mattermost.com"
    token: "YOUR_BOT_TOKEN"
    team_name: "your-team"

  webapp:
    port: 8686
    token: "YOUR_ACCESS_TOKEN"

# ── AI settings ───────────────────────────────────────────────────────────────
ai:
  max_rounds: 100     # max tool-call iterations per message
  call_timeout_secs: 90   # base timeout (seconds) for each AI API call; increase for slow local models like Ollama

  # Override AI provider per platform or per channel (legacy; prefer agents+bindings above)
  overrides:
    - platform: telegram
      provider: claude
    - platform: slack
      channel_id: C12345ABCDE    # optional: restrict to a specific channel
      provider: openai

  # External MCP tool servers — bot connects on startup and exposes their tools
  mcp_servers:
    - name: chrome
      command: npx
      args: ["chrome-devtools-mcp", "--browserUrl=http://127.0.0.1:9222"]
    # - name: my_server
    #   url: http://localhost:3000/sse

# ── Security ──────────────────────────────────────────────────────────────────
security:
  allowed_paths:
    - ~/Projects
    - ~/Documents
  blocked_commands:
    - "rm -rf /"
    - "mkfs"
  # require_confirmation: []    # commands that need user approval before running
  # disable_file_tools: false   # set true to block all file_read/file_write tools

# ── Logging ───────────────────────────────────────────────────────────────────
logging:
  level: info           # debug | info | warn | error
  file: /tmp/lingti-bot.log

# ── Browser automation ────────────────────────────────────────────────────────
# browser:
#   screen_size: fullscreen     # or e.g. 1280x800
#   cdp_url: "127.0.0.1:9222"
